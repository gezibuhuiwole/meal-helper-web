.page {
  padding: 32rpx 24rpx 48rpx;
}

.top {
  padding: 34rpx 28rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
}

.desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #6f5c50;
}

.entry-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.entry {
  padding: 28rpx;
}

.entry-title {
  font-size: 34rpx;
  font-weight: 700;
}

.entry-desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #6f5c50;
}

.entry-action {
  margin-top: 24rpx;
  color: #a45511;
  font-size: 26rpx;
  font-weight: 600;
}

.entry-disabled {
  opacity: 0.78;
}

.muted {
  color: #8d796b;
}
