<view class="page">
  <view class="top card">
    <view class="title">开始点餐</view>
    <view class="desc">选择点餐方式，快速安排今天的菜单。</view>
  </view>

  <view class="entry-list">
    <view class="entry card" bindtap="goMealPlan">
      <view class="entry-title">用餐时间</view>
      <view class="entry-desc">按早餐、午餐、晚餐安排菜品，自由组合今日菜单。</view>
      <view class="entry-action">进入选择</view>
    </view>

    <view class="entry card entry-disabled">
      <view class="entry-title">菜系</view>
      <view class="entry-desc">按菜系、风味和偏好浏览菜品。</view>
      <view class="entry-action muted">敬请期待</view>
    </view>
  </view>
</view>
