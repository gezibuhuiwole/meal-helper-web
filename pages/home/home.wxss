.page {
  padding: 32rpx 24rpx 48rpx;
}

.hero {
  padding: 28rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(180deg, #fff9f1 0%, #fffdf9 100%);
}

.hero-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #312217;
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6f5c50;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature {
  padding: 28rpx;
}

.feature-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.feature-title {
  font-size: 34rpx;
  font-weight: 700;
}

.feature-desc {
  font-size: 28rpx;
  line-height: 1.6;
  color: #6f5c50;
}

.badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.badge-active {
  background: #fbe4b1;
  color: #8a5a18;
}

.badge-coming {
  background: #efe7de;
  color: #8d796b;
}
