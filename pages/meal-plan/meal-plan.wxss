.page {
  padding: 20rpx 16rpx 36rpx;
  background: linear-gradient(180deg, #f7f1e8 0%, #fbf8f3 42%, #f4efe8 100%);
}

.summary-shell {
  position: sticky;
  top: 12rpx;
  z-index: 20;
}

.summary {
  padding: 22rpx;
  background: linear-gradient(180deg, #fffaf1 0%, #fffdf9 100%);
  box-shadow: 0 14rpx 30rpx rgba(125, 94, 49, 0.08);
}

.summary-topline {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.summary-main {
  min-width: 0;
}

.summary-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f2219;
}

.summary-meta {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6f5c50;
}

.meal-pill {
  flex-shrink: 0;
  max-width: 190rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #f2e4cf;
  color: #8a5a18;
  font-size: 20rpx;
  line-height: 1.4;
  text-align: center;
}

.stats {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.stat-box {
  padding: 16rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
}

.stat-label {
  font-size: 20rpx;
  color: #8d796b;
}

.stat-value {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #35261b;
}

.ingredient-strip {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid rgba(223, 197, 161, 0.4);
}

.ingredient-title {
  font-size: 23rpx;
  font-weight: 600;
  color: #624532;
}

.ingredient-scroll {
  width: 100%;
  margin-top: 12rpx;
}

.ingredient-list {
  display: inline-flex;
  gap: 10rpx;
  padding-right: 16rpx;
}

.ingredient-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #624532;
  font-size: 20rpx;
  white-space: nowrap;
}

.ingredient-empty {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #857163;
}

.workspace {
  margin-top: 18rpx;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.92);
}

.workspace-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
}

.workspace-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #302117;
}

.workspace-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7c6b5f;
}

.workspace-badge {
  flex-shrink: 0;
  max-width: 220rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #f4ebdf;
  color: #8b6236;
  font-size: 18rpx;
  line-height: 1.4;
  text-align: center;
}

.workspace-body {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.meal-tabs {
  width: 148rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.meal-tab {
  padding: 14rpx 12rpx;
  border-radius: 20rpx;
  background: #f6efe6;
  border: 2rpx solid transparent;
}

.meal-tab-current {
  background: #fff5e6;
  border-color: #ebb96f;
  box-shadow: 0 8rpx 18rpx rgba(205, 151, 73, 0.12);
}

.meal-tab-off {
  opacity: 0.72;
}

.meal-tab-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.meal-tab-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #332418;
}

.meal-tab-meta {
  font-size: 20rpx;
  color: #8c796b;
}

.meal-tab-switch {
  margin-top: 10rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.meal-tab-switch-on {
  background: #f7dfae;
  color: #8a5a18;
}

.meal-tab-switch-off {
  background: #e9e1d7;
  color: #7a695d;
}

.dish-grid-wrap {
  flex: 1;
  min-width: 0;
}

.filter-section {
  margin-bottom: 12rpx;
}

.filter-title {
  margin-bottom: 8rpx;
  font-size: 18rpx;
  color: #8a6b4d;
}

.category-tabs,
.dietary-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.category-chip,
.dietary-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #f5eee4;
  color: #7b6550;
  white-space: nowrap;
}

.category-chip-current,
.dietary-chip-current {
  background: #f7dfae;
  color: #7f511d;
}

.category-chip-label,
.dietary-chip-label {
  font-size: 18rpx;
  font-weight: 600;
}

.category-chip-count,
.dietary-chip-count {
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
}

.dish-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.dish-card {
  min-height: 168rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #f8f4ed;
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
}

.dish-card-selected {
  background: #fff0d4;
  border-color: #ebb96f;
}

.dish-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10rpx;
}

.dish-card-name {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #302117;
}

.dish-card-check {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #9a6526;
  font-size: 18rpx;
}

.dish-card-meta {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #78675b;
}

.dish-card-tags {
  margin-top: auto;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding-top: 14rpx;
}

.dish-card-tag {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #72563e;
  font-size: 18rpx;
}
